{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["ES2023"],
    "types": ["node", "bun-types"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "importHelpers": true,

    "preserveSymlinks": true,

    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./bundist",
    "declaration": true,
    "declarationMap": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@tsemekwes": ["./src"],
      "@tsemekwes/*": ["./src/*"],
      "@error": ["./src/error"],
      "@error/*": ["./src/error/*"],
      "@api": ["./src/api"],
      "@config": ["./src/config"],
      "@config/*": ["./src/config/*"],
      "@context": ["./src/context"],
      "@input": ["./src/input"],
      "@json": ["./src/json"],
      "@peg": ["./src/peg"],
      "@peg/*": ["./src/peg/*"],
      "@trees": ["./src/trees"],
      "@util": ["./src/util"],
      "@util/*": ["./src/util/*"],
    },
  },
  "include": ["src"],
  "exclude": ["**/*.js", "**/*.d.ts"],
}
