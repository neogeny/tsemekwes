{
  "compilerOptions": {
    "target": "es2023",
    "module": "NodeNext",
    "lib": ["ES2023"],   // Server/CLI tool — no DOM
    "types": ["node"],  // Node.js API (process, Buffer, etc.)
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* Emit mode for Libraries */
    "moduleResolution": "NodeNext", // Ensures standard Node ecosystem compatibility
    "rootDir": "./src",
    "outDir": "./dist",             // Where the compiled files will land
    "declaration": true,            // Generates the .d.ts type files for library consumers
    "declarationMap": true,         // Maps types back to source files for IDE debugging

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@totetsu/*": ["./src/*"],
      "@config/*": ["./src/config/*"],
      "@input/*": ["./src/input/*"],
      "@trees/*": ["./src/trees/*"],
      "@context/*": ["./src/context/*"],
      "@peg/*": ["./src/peg/*"],
      "@json/*": ["./src/json/*"],
      "@api/*": ["./src/api/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",   // Exclude internal tests from the final build
    "tests/**/*"          // Exclude the outer integration directory
  ]
}
